{
    "manifest_version": 3,
    "name": "OpenBiliClaw",
    "version": "0.3.42",
    "description": "跨平台内容发现 AI Agent — 行为采集、画像与智能推荐",
    "permissions": [
        "activeTab",
        "alarms",
        "cookies",
        "notifications",
        "scripting",
        "sidePanel",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "*://*.bilibili.com/*",
        "*://*.xiaohongshu.com/*",
        "*://*.douyin.com/*",
        "*://*.youtube.com/*",
        "http://127.0.0.1/*",
        "http://localhost/*",
        "http://*/*"
    ],
    "background": {
        "service_worker": "dist/background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.bilibili.com/*"
            ],
            "js": [
                "dist/content/bilibili.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://*.xiaohongshu.com/*"
            ],
            "js": [
                "dist/content/xiaohongshu.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://*.xiaohongshu.com/*"
            ],
            "js": [
                "dist/main/xhs-token-sniffer.js",
                "dist/main/xhs-state-bridge.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "*://*.douyin.com/*"
            ],
            "js": [
                "dist/content/douyin.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "dist/content/youtube.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "dist/main/dy-fetch-tap.js"
            ],
            "matches": [
                "*://*.douyin.com/*"
            ]
        }
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "side_panel": {
        "default_path": "popup/popup.html"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
