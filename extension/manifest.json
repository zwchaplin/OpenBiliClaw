{
    "manifest_version": 3,
    "name": "OpenBiliClaw",
    "version": "0.2.0",
    "description": "你的 B 站专属 AI 朋友 — 行为采集与智能推荐",
    "permissions": [
        "activeTab",
        "alarms",
        "notifications",
        "sidePanel",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "*://*.bilibili.com/*",
        "*://*.xiaohongshu.com/*",
        "http://127.0.0.1:8420/*",
        "http://localhost:8420/*"
    ],
    "background": {
        "service_worker": "dist/background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.bilibili.com/*"
            ],
            "js": [
                "dist/content/bilibili.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://*.xiaohongshu.com/*"
            ],
            "js": [
                "dist/content/xiaohongshu.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://*.xiaohongshu.com/*"
            ],
            "js": [
                "dist/main/xhs-token-sniffer.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        }
    ],
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "side_panel": {
        "default_path": "popup/popup.html"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
